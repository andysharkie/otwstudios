# ─────────────────────────────────────────────────────────────────────────────
# OTW Studios — Environment Variables
# Copy this file to .env.local for local development
# Add all these as Vercel Environment Variables in production
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key     # "service_role" key (not anon key)

# ── Google OAuth (Gmail API) ──────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://otwstudios.com.au/api/auth/callback
# For local dev: http://localhost:3000/api/auth/callback

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get from: Google AI Studio → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development    # Set to "production" on Vercel (auto-set)
